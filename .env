# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegistrade

# API & WebSocket URLs
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
WS_URL=ws://localhost:8000/ws/market
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market

# Market Maker Bootstrap
MARKET_MAKER_CASH=1000000
MARKET_MAKER_INVENTORY=10000

# Simulation Settings
SIMULATION_INTERVAL_SECONDS=1.0

# Algorithm Bot Configuration - SMA
ALGO_USER_ID=algo-sma
ALGO_SYMBOL=AAPL
ALGO_ORDER_QTY=10

# Algorithm Bot Configuration - RSI
ALGO_RSI_USER_ID=algo-rsi
ALGO_RSI_SYMBOL=AAPL
ALGO_RSI_ORDER_QTY=10
ALGO_RSI_WINDOW=14

# Algorithm Bot Configuration - EMA
ALGO_EMA_USER_ID=algo-ema
ALGO_EMA_SYMBOL=AAPL
ALGO_EMA_ORDER_QTY=10
ALGO_EMA_FAST_WINDOW=12
ALGO_EMA_SLOW_WINDOW=26

# Algorithm Bot Configuration - Bollinger Bands
ALGO_BOLLINGER_USER_ID=algo-bollinger
ALGO_BOLLINGER_SYMBOL=AAPL
ALGO_BOLLINGER_ORDER_QTY=10
ALGO_BOLLINGER_WINDOW=20
ALGO_BOLLINGER_STD=2.0

# Algorithm Bot Configuration - MACD
ALGO_MACD_USER_ID=algo-macd
ALGO_MACD_SYMBOL=AAPL
ALGO_MACD_ORDER_QTY=10
ALGO_MACD_FAST_WINDOW=12
ALGO_MACD_SLOW_WINDOW=26
ALGO_MACD_SIGNAL_WINDOW=9

# Algorithm Bot Configuration - Donchian Channels
ALGO_DONCHIAN_USER_ID=algo-donchian
ALGO_DONCHIAN_SYMBOL=AAPL
ALGO_DONCHIAN_ORDER_QTY=10
ALGO_DONCHIAN_WINDOW=21

# Algorithm Bot Configuration - ROC (Rate of Change)
ALGO_ROC_USER_ID=algo-roc
ALGO_ROC_SYMBOL=AAPL
ALGO_ROC_ORDER_QTY=10
ALGO_ROC_WINDOW=12
